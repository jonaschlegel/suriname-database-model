---
title: Organization (E74) + PICO Connection Pattern
---
flowchart TB
    subgraph CIDOC_CRM["CIDOC-CRM Domain"]
        direction TB
        E74["E74 Group<br/>(Organization)<br/>wd:Q-ID"]
        E25["E25 Human-Made Feature<br/>(Plantation)<br/>plantation/slug"]
        E53["E53 Place<br/>place/fid"]
        E41_MAP["E41 Appellation<br/>Map label (identifies E25)"]
        E41_ALM["E41 Appellation<br/>Almanac name (identifies E74)"]

        E25 -->|"P52 has current owner"| E74
        E25 -->|"P53 has former or current location"| E53
        E25 -->|"P1 is identified by"| E41_MAP
        E74 -->|"P1 is identified by"| E41_ALM
        E41_MAP ---|"P139 has alt form"| E41_ALM
    end

    subgraph PICO_Domain["PICO Domain"]
        direction TB
        PERSON_OBS["pico:PersonObservation<br/>(raw source data)"]
        PERSON_REC["pico:PersonReconstruction<br/>(derived person)"]
        SOURCE["sdo:ArchiveComponent<br/>(source document)"]

        PERSON_OBS -->|"prov:hadPrimarySource"| SOURCE
        PERSON_OBS -.->|"pico:derivesTo"| PERSON_REC
    end

    subgraph ROLES["Person Roles in Plantation Context"]
        direction LR
        OWNER["picot:owner"]
        ADMIN["picot:administrator"]
        ENSLAVED["hdsc:enslaved"]
        DIRECTOR["picot:director"]
    end

    %% Cross-domain connections
    E74 -->|"P107 has current or former member"| PERSON_REC
    PERSON_OBS -->|"pico:hasRole"| ROLES

    %% Enslaved relationship modeled explicitly
    ENSLAVED -->|"hdsc:isEnslavedOf"| E74

    %% Schema.org for organization properties
    E74 -->|"sdo:additionalType"| TYPE["wd:Q188913<br/>plantation type"]
    E74 -->|"owl:sameAs"| WD["wikidata:Q-ID"]

    subgraph OBSERVATION_LAYER["Temporal Observations (Almanakken)"]
        direction TB
        OBS1["E13 Attribute Assignment 1823<br/>eigenaren | administrateurs | directeuren"]
        OBS2["E13 Attribute Assignment 1847<br/>eigenaren | administrateurs | directeuren"]
        OBS3["Slave Register Entry 1863"]

        OBS1 -->|"P14 carried out by"| PERSON_OBS
        OBS2 -->|"P14 carried out by"| PERSON_OBS
        OBS3 -->|"observes enslaved person"| PERSON_OBS
    end

    OBS1 -->|"P140 assigned attribute to"| E74
    OBS2 -->|"P140 assigned attribute to"| E74

    %% Source carries almanac names
    SOURCE -->|"P128 carries"| E41_ALM

    %% Style definitions
    %% CRITERIA / George Bruseker CIDOC-CRM colour scheme
    %% See: https://github.com/chin-rcip/CRITERIA

    classDef crm_E18_Physical_Thing fill:#c78e66,stroke:#000000,color:#000000
    classDef crm_E53_Place fill:#94cc7d,stroke:#000000,color:#000000
    classDef crm_E39_Actor fill:#ffbdca,stroke:#000000,color:#000000
    classDef crm_E41_Appellation fill:#fef3ba,stroke:#000000,color:#000000
    classDef crm_E2_Temporal_Entity fill:#82ddff,stroke:#000000,color:#000000
    classDef crm_E39_Actor_URI fill:#ffe6eb,stroke:#000000,color:#000000
    classDef Literal fill:#ffffff,stroke:#000000,color:#000000

    class E74 crm_E39_Actor
    class E25 crm_E18_Physical_Thing
    class E53 crm_E53_Place
    class E41_MAP,E41_ALM crm_E41_Appellation
    class PERSON_OBS,PERSON_REC,SOURCE crm_E39_Actor_URI
    class OWNER,ADMIN,ENSLAVED,DIRECTOR Literal
    class OBS1,OBS2,OBS3 crm_E2_Temporal_Entity
    class TYPE,WD Literal
