---
title: Suriname Time Machine - Universal Source Pattern (CIDOC-CRM)
---
%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#e8f4ea'}}}%%
flowchart TB
    %% =============================================================
    %% UNIVERSAL SOURCE PATTERN
    %% Applies to: Maps, Almanacs, Slave Registers, Certificates
    %% =============================================================

    E22["E22 Human-Made Object
    (Physical source artifact)
    Map | Book | Ledger | Document"]

    E36_IMG["E36 Visual Item
    (Digital reproduction)
    IIIF scan"]

    E36["E36 Visual Item
    (What the artifact carries)
    Cartography | Tables | Handwriting"]

    E41_MAP["E41 Appellation
    (Map label identifies E25)
    P190: printed name"]

    E41_ALM["E41 Appellation
    (Almanac name identifies E74)
    P190: handwritten name"]

    E12["E12 Production"]

    E52["E52 Time-Span
    P82a begin: YYYY-01-01
    P82b end: YYYY-12-31"]

    E21["E21 Person
    (Makers)"]

    E74_PUB["E74 Group
    (Publisher)"]

    %% =============================================================
    %% WHAT THE SOURCE REPRESENTS (varies by source type)
    %% =============================================================

    E25["E25 Human-Made Feature
    (Plantations, buildings)
    plantation/slug"]

    E26["E26 Physical Feature
    (Rivers, creeks)"]

    E74_ORG["E74 Group
    (Organizations)
    wd:Q-ID"]

    E21_PERSON["E21 Person
    (Historical persons)"]

    E53["E53 Place
    (Spatial location)"]

    %% =============================================================
    %% RELATIONSHIPS
    %% =============================================================

    %% Physical artifact carries visual content AND names
    E22 -->|"P128 carries"| E36
    E22 -->|"P128 carries"| E41_MAP
    E22 -->|"P128 carries"| E41_ALM

    %% Digital scan represents physical (P138)
    E36_IMG -->|"P138 represents"| E22

    %% Production with time-span (gives temporal scope to names)
    E22 -->|"P108i was produced by"| E12
    E12 -->|"P4 has time-span"| E52
    E12 -->|"P14 carried out by"| E21
    E12 -->|"P14 carried out by"| E74_PUB

    %% Visual represents different things depending on source type
    E36 -->|"P138 represents"| E25
    E36 -->|"P138 represents"| E26
    E36 -->|"P138 represents"| E74_ORG
    E36 -->|"P138 represents"| E21_PERSON

    %% Names identify DIFFERENT entity types depending on source
    E41_MAP -->|"P1i identifies"| E25
    E41_ALM -->|"P1i identifies"| E74_ORG
    E41_MAP ---|"P139 has alt form"| E41_ALM

    %% Things/features have locations
    E25 -->|"P53 has location"| E53
    E26 -->|"P53 has location"| E53

    %% Plantation owned by organization (separate entities)
    E25 -->|"P52 has current owner"| E74_ORG

    %% =============================================================
    %% STYLING
    %% =============================================================

    %% CRITERIA / George Bruseker CIDOC-CRM colour scheme
    %% See: https://github.com/chin-rcip/CRITERIA

    classDef crm_E18_Physical_Thing fill:#c78e66,stroke:#000000,color:#000000
    classDef crm_E28_Conceptual_Object fill:#fddc34,stroke:#000000,color:#000000
    classDef crm_E41_Appellation fill:#fef3ba,stroke:#000000,color:#000000
    classDef crm_E53_Place fill:#94cc7d,stroke:#000000,color:#000000
    classDef crm_E39_Actor fill:#ffbdca,stroke:#000000,color:#000000
    classDef crm_E2_Temporal_Entity fill:#82ddff,stroke:#000000,color:#000000
    classDef crm_E52_Time_Span fill:#86bcc8,stroke:#000000,color:#000000

    class E22 crm_E18_Physical_Thing
    class E36_IMG crm_E28_Conceptual_Object
    class E36 crm_E28_Conceptual_Object
    class E41_MAP crm_E41_Appellation
    class E41_ALM crm_E41_Appellation
    class E25 crm_E18_Physical_Thing
    class E53 crm_E53_Place
    class E26 crm_E18_Physical_Thing
    class E74_ORG crm_E39_Actor
    class E74_PUB crm_E39_Actor
    class E21,E21_PERSON crm_E39_Actor
    class E12 crm_E2_Temporal_Entity
    class E52 crm_E52_Time_Span
