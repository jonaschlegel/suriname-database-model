{
  "@context": {
    "@vocab": "https://schema.org/",
    "stm": "https://suriname-timemachine.org/ontology/",
    "wd": "http://www.wikidata.org/entity/",
    "wdt": "http://www.wikidata.org/prop/direct/",
    "crm": "http://www.cidoc-crm.org/cidoc-crm/",
    "geo": "http://www.opengis.net/ont/geosparql#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "picom": "https://personsincontext.org/model#",
    "pnv": "https://w3id.org/pnv#",
    "sdo": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "ed": "https://lod.enslaved.org/wiki/",
    "Plantation": "stm:Plantation",
    "PlantationObservation": "stm:PlantationObservation",
    "MapDepiction": "stm:MapDepiction",
    "psurId": {
      "@id": "stm:psurId",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "stm:status",
      "@type": "xsd:string"
    },
    "geometrySource": {
      "@id": "stm:geometrySource",
      "@type": "@id"
    },
    "validFrom": {
      "@id": "stm:validFrom",
      "@type": "xsd:gYear"
    },
    "validThrough": {
      "@id": "stm:validThrough",
      "@type": "xsd:gYear"
    },
    "source": {
      "@id": "stm:source",
      "@type": "xsd:string"
    },
    "hasObservation": {
      "@id": "stm:hasObservation",
      "@type": "@id"
    },
    "depictedOnMap": {
      "@id": "stm:depictedOnMap",
      "@type": "@id"
    },
    "labelOnMap": {
      "@id": "stm:labelOnMap",
      "@type": "xsd:string"
    },
    "observationYear": {
      "@id": "stm:observationYear",
      "@type": "xsd:gYear"
    },
    "product": {
      "@id": "stm:product",
      "@type": "xsd:string"
    },
    "enslavedCount": {
      "@id": "stm:enslavedCount",
      "@type": "xsd:integer"
    },
    "prefLabel": "skos:prefLabel",
    "altLabel": "skos:altLabel",
    "hasGeometry": "geo:hasGeometry",
    "asWKT": {
      "@id": "geo:asWKT",
      "@type": "geo:wktLiteral"
    },
    "P138i_has_representation": {
      "@id": "crm:P138i_has_representation",
      "@type": "@id"
    },
    "P46_is_composed_of": {
      "@id": "crm:P46_is_composed_of",
      "@type": "@id",
      "@comment": "Plantation split parts (has_parts)"
    },
    "P46i_forms_part_of": {
      "@id": "crm:P46i_forms_part_of",
      "@type": "@id",
      "@comment": "Merged into larger plantation (partof)"
    },
    "P52_has_current_owner": {
      "@id": "crm:P52_has_current_owner",
      "@type": "@id",
      "@comment": "Ownership relation (reference_std)"
    },
    "P92i_was_brought_into_existence_by": {
      "@id": "crm:P92i_was_brought_into_existence_by",
      "@type": "@id"
    },
    "P93i_was_taken_out_of_existence_by": {
      "@id": "crm:P93i_was_taken_out_of_existence_by",
      "@type": "@id"
    },
    "additionalType": {
      "@id": "sdo:additionalType",
      "@type": "@id"
    },
    "affiliation": {
      "@id": "sdo:affiliation",
      "@type": "@id"
    },
    "parentOrganization": {
      "@id": "sdo:parentOrganization",
      "@type": "@id"
    },
    "subOrganization": {
      "@id": "sdo:subOrganization",
      "@type": "@id"
    },
    "hasAdministrator": {
      "@id": "stm:hasAdministrator",
      "@type": "@id",
      "@comment": "Future: link to Person (administrateurs)"
    },
    "hasDirector": {
      "@id": "stm:hasDirector",
      "@type": "@id",
      "@comment": "Future: link to Person (directeuren)"
    },
    "hasOwner": {
      "@id": "stm:hasOwner",
      "@type": "@id",
      "@comment": "Future: link to Person (eigenaren)"
    },
    "location": {
      "@id": "stm:location",
      "@type": "xsd:string",
      "@comment": "Standardized location (loc_std)"
    },
    "size": {
      "@id": "stm:size",
      "@type": "xsd:integer",
      "@comment": "Size in akkers (size_std)"
    },
    "deserted": {
      "@id": "stm:deserted",
      "@type": "xsd:boolean"
    },
    "freeResidentsCount": {
      "@id": "stm:freeResidentsCount",
      "@type": "xsd:integer"
    },
    "isEnslavedBy": {
      "@id": "stm:isEnslavedBy",
      "@type": "@id"
    },
    "isEnslaverOf": {
      "@id": "stm:isEnslaverOf",
      "@type": "@id"
    }
  }
}
