    {
      "@id": "https://data.suriname-timemachine.org/source/almanakken",
      "@type": [
        "crm:E22_Human-Made_Object"
      ],
      "sourceId": "almanakken",
      "prefLabel": "Surinaamse Almanakken (1818-1861)",
      "P2_has_type": "https://data.suriname-timemachine.org/type/source-type/almanac",
      "timeSpan": "1818-1861",
      "publicationPlace": "Paramaribo",
      "linkedToGazetteer": true,
      "description": "Annual plantation observation records from the Surinaamse Almanakken. Contains ownership, production, enslaved counts, and plantation names for each year. Modeled as a single E22 source with individual E13 observations per row."
    },
    {
      "@id": "https://data.suriname-timemachine.org/source/slave-registers",
