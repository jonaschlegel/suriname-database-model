      ],
      "typeId": "creek",
      "color": "#6baed6",
      "crmClass": "E26_Physical_Feature",
      "crmBadge": "E26",
      "sortOrder": 11,
      "created": "2026-04-07",
      "modified": "2026-04-07"
    },
    {
      "@id": "stm:vocabulary/place-type/district",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "District",
        "nl": "District",
        "srn": "Distrikt"
      },
      "definition": {
        "en": "An administrative subdivision of Suriname used for governance and census purposes.",
        "nl": "Een bestuurlijke onderverdeling van Suriname voor bestuur en volkstelling."
      },
      "inScheme": "stm:vocabulary/place-type",
      "broader": "stm:vocabulary/place-type/administrative",
