  "@graph": [
    {
      "@id": "stm:vocabulary/place-type",
      "@type": "skos:ConceptScheme",
      "prefLabel": {
        "en": "Geographical Features Thesaurus",
        "nl": "Thesaurus Geografische Kenmerken"
      },
      "scopeNote": {
        "en": "This vocabulary describes place types found in colonial-era sources from Suriname. Preferred labels use modern, non-colonial terminology. Alternative labels preserve original source terms for scholarly reference, with editorial notes documenting colonial bias. See also: docs/concepts/ethical-framework.md",
        "nl": "Dit vocabulaire beschrijft plaatstypen uit koloniale bronnen van Suriname. Voorkeurslabels gebruiken moderne, niet-koloniale terminologie. Alternatieve labels bewaren originele brontermen voor wetenschappelijke referentie, met redactionele notities over koloniaal vooroordeel."
      },
      "hasTopConcept": [
        "stm:vocabulary/place-type/human-made",
        "stm:vocabulary/place-type/natural",
        "stm:vocabulary/place-type/administrative"
      ],
      "created": "2026-04-07",
      "modified": "2026-04-07"
    },
    {
      "@id": "stm:vocabulary/place-type/human-made",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "Human-Made Feature",
        "nl": "Menselijk Bouwwerk"
      },
      "definition": {
        "en": "A physical feature created or substantially modified by human activity."
      },
      "topConceptOf": "stm:vocabulary/place-type",
      "inScheme": "stm:vocabulary/place-type",
      "crmClass": "E25_Human-Made_Feature",
      "crmBadge": "E25",
      "narrower": [
        "stm:vocabulary/place-type/plantation",
        "stm:vocabulary/place-type/military-post",
        "stm:vocabulary/place-type/road",
        "stm:vocabulary/place-type/railroad",
        "stm:vocabulary/place-type/station",
        "stm:vocabulary/place-type/settlement"
      ]
    },
    {
      "@id": "stm:vocabulary/place-type/natural",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "Natural Feature",
        "nl": "Natuurlijk Kenmerk",
        "srn": "Naturu sani"
      },
      "definition": {
        "en": "A geographical feature formed by natural processes, not substantially modified by human activity."
      },
      "topConceptOf": "stm:vocabulary/place-type",
      "inScheme": "stm:vocabulary/place-type",
      "crmClass": "E26_Physical_Feature",
      "crmBadge": "E26",
      "narrower": [
        "stm:vocabulary/place-type/river",
        "stm:vocabulary/place-type/creek"
      ]
    },
    {
      "@id": "stm:vocabulary/place-type/administrative",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "Administrative Division",
        "nl": "Administratieve Indeling"
      },
      "definition": {
        "en": "A formally defined area used for governance, census, or administrative purposes."
      },
      "topConceptOf": "stm:vocabulary/place-type",
      "inScheme": "stm:vocabulary/place-type",
      "crmClass": "E53_Place",
      "crmBadge": "E53",
      "narrower": [
        "stm:vocabulary/place-type/district"
      ]
    },
    {
      "@id": "stm:vocabulary/place-type/plantation",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "Plantation",
        "nl": "Plantage",
        "srn": "Plantasi"
      },
      "definition": {
        "en": "A large agricultural estate, typically established during the colonial period for the production of export crops using enslaved labor.",
        "nl": "Een groot landbouwbedrijf, doorgaans opgericht tijdens de koloniale periode voor de productie van exportgewassen met gebruik van tot slaaf gemaakte arbeid."
      },
      "editorialNote": {
        "en": "Colonial data bias: Plantations were the primary sites of enslaved labor in Suriname. The term itself carries the weight of colonial exploitation."
      },
      "inScheme": "stm:vocabulary/place-type",
      "broader": "stm:vocabulary/place-type/human-made",
      "related": [
        "stm:vocabulary/place-type/settlement"
      ],
      "exactMatch": [
        "http://www.wikidata.org/entity/Q188913"
      ],
      "typeId": "plantation",
      "color": "#a67830",
      "crmClass": "E25_Human-Made_Feature",
      "crmBadge": "E25",
      "sortOrder": 1,
      "created": "2026-04-07",
      "modified": "2026-04-07"
    },
    {
      "@id": "stm:vocabulary/place-type/military-post",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "Military Post",
        "nl": "Militaire Post"
      },
      "altLabel": {
        "nl": [
          "voormalige militaire post (1882 map)"
        ]
      },
      "definition": {
        "en": "A fortified position or garrison established for military defense or territorial control.",
        "nl": "Een versterkte positie of garnizoen opgericht voor militaire verdediging of territoriale controle."
      },
      "editorialNote": {
        "en": "Colonial data bias: Military posts were instruments of colonial territorial control and surveillance of Maroon and Indigenous communities.",
        "nl": "Koloniaal vooroordeel: Militaire posten waren instrumenten van koloniale territoriale controle en toezicht op Marron- en Inheemse gemeenschappen."
      },
      "inScheme": "stm:vocabulary/place-type",
      "broader": "stm:vocabulary/place-type/human-made",
      "related": [
        "stm:vocabulary/place-type/settlement"
      ],
      "closeMatch": [
        "http://www.wikidata.org/entity/Q245016"
      ],
      "typeId": "military-post",
      "color": "#c0392b",
      "crmClass": "E25_Human-Made_Feature",
      "crmBadge": "E25",
      "sortOrder": 2,
      "created": "2026-04-07",
      "modified": "2026-04-07"
    },
    {
