    },
    {
      "@id": "stm:vocabulary/place-type/station",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "Astronomical Station",
        "nl": "Astronomisch Station",
        "srn": "Stasi"
      },
      "definition": {
        "nl": "Geodetisch meetpunt",
        "en": "Geodetic control point used as referencing point for map making",
        "srn": "Lanti-marki [?]"
      },
      "inScheme": "stm:vocabulary/place-type",
      "broader": "stm:vocabulary/place-type/human-made",
      "closeMatch": [
        "https://www.wikidata.org/wiki/Q1408783"
      ],
      "typeId": "station",
      "color": "#2c3e50",
      "crmClass": "E25_Human-Made_Feature",
      "crmBadge": "E25",
      "sortOrder": 5,
      "created": "2026-04-07",
      "modified": "2026-04-09"
    },
    {
      "@id": "stm:vocabulary/place-type/settlement",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "Settlement",
        "nl": "Nederzetting"
      },
      "altLabel": {
        "nl": [
          "Leprozen etablissement",
          "strafetablissement",
          "voormalige Gouvernements kostgrond",
          "Posto (1882 map)"
        ]
      },
      "definition": {
        "en": "A place where people have established a community and live together.",
        "nl": "Een plaats waar mensen een gemeenschap hebben gevestigd en samenleven."
      },
      "editorialNote": {
        "en": "Colonial data bias: Several settlements have colonial institutional origins (leper colonies, penal establishments, government provisions grounds) reflecting colonial governance structures.",
        "nl": "Koloniaal vooroordeel: Diverse nederzettingen hebben koloniale institutionele oorsprong (leprozenkolonies, strafgestichten, gouvernements kostgronden) die koloniale bestuursstructuren weerspiegelen."
      },
      "inScheme": "stm:vocabulary/place-type",
      "broader": "stm:vocabulary/place-type/human-made",
      "related": [
        "stm:vocabulary/place-type/plantation"
      ],
      "exactMatch": [
        "http://www.wikidata.org/entity/Q486972"
      ],
      "narrower": [
        "stm:vocabulary/place-type/town",
        "stm:vocabulary/place-type/indigenous-village",
        "stm:vocabulary/place-type/maroon-village"
      ],
      "typeId": "settlement",
      "color": "#8b7355",
      "crmClass": "E25_Human-Made_Feature",
      "crmBadge": "E25",
      "sortOrder": 6,
      "created": "2026-04-07",
      "modified": "2026-04-07"
    },
    {
      "@id": "stm:vocabulary/place-type/town",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "Town",
        "nl": "Stad",
        "srn": "Foto"
      },
      "definition": {
        "en": "A densely populated settlement with defined boundaries and local governance.",
        "nl": "Een dichtbevolkte nederzetting met vaste grenzen en lokaal bestuur."
      },
      "inScheme": "stm:vocabulary/place-type",
      "broader": "stm:vocabulary/place-type/settlement",
      "exactMatch": [
        "http://www.wikidata.org/entity/Q3957"
      ],
      "typeId": "town",
      "color": "#d4a853",
      "crmClass": "E25_Human-Made_Feature",
      "crmBadge": "E25",
      "sortOrder": 7,
      "created": "2026-04-07",
      "modified": "2026-04-07"
    },
    {
      "@id": "stm:vocabulary/place-type/indigenous-village",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "Indigenous Village",
        "nl": "Inheems Dorp"
      },
      "altLabel": {
        "nl": [
          "Indiaansch dorp",
          "Indianen (1882 map)"
        ],
        "en": [
          "I (1930 map code)"
        ]
      },
      "definition": {
        "en": "A settlement of Indigenous peoples of Suriname.",
        "nl": "Een nederzetting van Inheemse volkeren van Suriname."
      },
      "editorialNote": {
        "en": "Colonial data bias: \"I\" and \"Indiaansch dorp\" are colonial Dutch terms from the 1930 and 1882 plantation maps. Indigenous communities were reduced to single-letter codes. The preferred term recognizes the self-determination of these communities.",
        "nl": "Koloniaal vooroordeel: \"I\" en \"Indiaansch dorp\" zijn koloniale Nederlandse termen uit de plantagekaarten van 1930 en 1882. Inheemse gemeenschappen werden gereduceerd tot codes van een enkele letter."
      },
      "inScheme": "stm:vocabulary/place-type",
      "broader": "stm:vocabulary/place-type/settlement",
      "typeId": "indigenous-village",
      "color": "#27ae60",
      "crmClass": "E25_Human-Made_Feature",
      "crmBadge": "E25",
      "sortOrder": 8,
      "created": "2026-04-07",
      "modified": "2026-04-07"
    },
    {
      "@id": "stm:vocabulary/place-type/maroon-village",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "Maroon Village",
        "nl": "Marrondorp",
        "srn": "Marunkondre"
      },
      "altLabel": {
        "nl": [
          "Boschdorp",
          "Boschnegers dorp",
          "Boschneger"
        ],
        "en": [
          "B (1930 map code)"
        ]
      },
      "definition": {
        "en": "A settlement established by Maroon communities -- self-liberated formerly enslaved people and their descendants.",
        "nl": "Een nederzetting opgericht door Marrongemeenschappen -- zelfbevrijde voorheen tot slaaf gemaakte mensen en hun nakomelingen."
      },
      "editorialNote": {
        "en": "Colonial data bias: \"Boschnegers\" (lit. \"bush negroes\") was a derogatory Dutch colonial designation for Maroon communities. The preferred term \"Maroon\" respects their agency and self-identification.",
        "nl": "Koloniaal vooroordeel: \"Boschnegers\" was een denigrerende Nederlandse koloniale aanduiding voor Marrongemeenschappen. De voorkeursterm \"Marron\" respecteert hun eigen identiteit en zelfbeschikking."
      },
      "inScheme": "stm:vocabulary/place-type",
      "broader": "stm:vocabulary/place-type/settlement",
      "closeMatch": [
        "http://www.wikidata.org/entity/Q5765472"
      ],
      "typeId": "maroon-village",
      "color": "#8e44ad",
      "crmClass": "E25_Human-Made_Feature",
      "crmBadge": "E25",
      "sortOrder": 9,
      "created": "2026-04-07",
      "modified": "2026-04-07"
    },
    {
      "@id": "stm:vocabulary/place-type/river",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "River",
        "nl": "Rivier",
        "srn": "Liba"
      },
      "definition": {
        "en": "A large natural flowing watercourse, typically emptying into the sea or a larger body of water.",
        "nl": "Een grote natuurlijke waterloop die doorgaans uitmondt in de zee of een groter waterlichaam."
      },
      "inScheme": "stm:vocabulary/place-type",
      "broader": "stm:vocabulary/place-type/natural",
      "exactMatch": [
        "http://www.wikidata.org/entity/Q4022"
      ],
      "typeId": "river",
      "color": "#3182bd",
      "crmClass": "E26_Physical_Feature",
      "crmBadge": "E26",
      "sortOrder": 10,
      "created": "2026-04-07",
      "modified": "2026-04-07"
    },
    {
      "@id": "stm:vocabulary/place-type/creek",
      "@type": [
        "skos:Concept",
        "crm:E55_Type"
      ],
      "prefLabel": {
        "en": "Creek",
        "nl": "Kreek",
        "srn": "Kriki"
      },
      "definition": {
        "en": "A small to medium natural watercourse, often a tributary of a river.",
        "nl": "Een kleine tot middelgrote natuurlijke waterloop, vaak een zijrivier."
      },
      "inScheme": "stm:vocabulary/place-type",
      "broader": "stm:vocabulary/place-type/natural",
